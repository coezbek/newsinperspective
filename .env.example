# ─────────────────────────────────────────────────────────────────────────────
# Core service config
# ─────────────────────────────────────────────────────────────────────────────

# Postgres connection string used by Prisma. The default matches the container
# started by `pnpm db:start` (port 55432, db `news_in_perspective`).
DATABASE_URL="postgresql://postgres:postgres@localhost:55432/news_in_perspective?schema=public"

# Fastify API bind address and port.
PORT=4400
HOST=0.0.0.0

# Origin allowed by the API's CORS policy. Must match where the Svelte
# frontend (`pnpm web:start`) is served from.
WEB_ORIGIN="http://localhost:5317"

# Logical "run date" timezone. Stored timestamps stay UTC instants in
# Postgres; this only affects which calendar day a run is bucketed under.
APP_DATE_TIMEZONE="UTC"

# ─────────────────────────────────────────────────────────────────────────────
# Ingestion source (Kagi News / Kite)
# ─────────────────────────────────────────────────────────────────────────────

# Public Kagi Kite feed catalog (used by the legacy RSS path; current
# cluster-based ingestion fetches snapshots from kite.kagi.com directly).
KAGI_KITE_URL="https://raw.githubusercontent.com/kagisearch/kite-public/main/kite_feeds.json"

# When true, the in-process scheduler enqueues the daily 5-stage pipeline at
# AUTO_INGEST_TIME_UTC. Leave false for local dev; flip on for a deployed
# instance that should run itself.
AUTO_INGEST=false
AUTO_INGEST_TIME_UTC="12:30"

# HTTP timeouts for the legacy RSS / article fetchers (milliseconds).
RSS_FETCH_TIMEOUT_MS=10000
ARTICLE_FETCH_TIMEOUT_MS=15000
ARTICLE_FETCH_USER_AGENT="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/136.0.0.0 Safari/537.36"

# Headless-Chromium navigation timeout for the Playwright extractor used by
# the cluster-based ingest.
ARTICLE_BROWSER_TIMEOUT_MS=30000

# Cap on RSS feeds per legacy ingest run. 50 keeps first runs fast while you
# validate the pipeline; raise or remove for full collection.
INGEST_FEED_LIMIT=50

# Kagi ingest extraction (Playwright headless Chromium) concurrency.
# Each unit = one Chrome page in flight. Lower if your machine struggles.
KAGI_INGEST_EXTRACTION_CONCURRENCY=4
KAGI_INGEST_EXTRACTION_PER_DOMAIN_CONCURRENCY=2
KAGI_INGEST_EXTRACTION_RETRIES=1

# Skip clusters already present in DB (matched by storyId + snapshot date).
# Set to "false" to force re-extraction of every selected cluster.
# `pnpm pipeline:run` overrides this to false so reruns refresh bodies.
KAGI_INGEST_SKIP_EXISTING=true

# Cluster-level dedupe strategy. "simhash" compares article-body simhashes
# inside a story cluster and merges near-duplicates above the Jaccard
# threshold below.
KAGI_DEDUPE_STRATEGY="simhash"
KAGI_DEDUPE_SIMHASH_MIN_JACCARD=0.90

# ─────────────────────────────────────────────────────────────────────────────
# LLM providers (REQUIRED for stage 2 enrichment)
# ─────────────────────────────────────────────────────────────────────────────
# Stage 2 of the daily pipeline (translation, framing summary, keywords,
# entity lists) needs at least one working LLM provider. The pipeline tries
# OpenRouter free models first and falls back to OpenAI only after the free
# pool is exhausted. Without these keys, stages 2-5 will not produce useful
# output.

# OpenRouter API key — get one at https://openrouter.ai/keys (free to sign
# up; the listed models below are zero-cost). This is the primary LLM path.
OPENROUTER_API_KEY="sk-or-v1-...."

# Free-model rotation, refreshed against https://openrouter.ai/collections/free-models.
# Ordered with structured-output / function-calling models first. The
# enrichment loop walks this list, retrying the next model when one is
# rate-limited or returns malformed JSON. You can override with a single
# model or a comma-separated subset.
OPENROUTER_MODEL="openai/gpt-oss-120b:free,google/gemma-4-31b-it:free,google/gemma-4-26b-a4b-it:free,openai/gpt-oss-20b:free,tencent/hy3-preview:free,nvidia/nemotron-3-super-120b-a12b:free,inclusionai/ling-2.6-1t:free,z-ai/glm-4.5-air:free,minimax/minimax-m2.5:free,openrouter/owl-alpha,nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free,nvidia/nemotron-3-nano-30b-a3b:free,poolside/laguna-m.1:free,poolside/laguna-xs.2:free"

# Start the rotation at this offset. Bump it if the leading models are hot
# and consistently rate-limiting your runs.
OPENROUTER_MODEL_OFFSET=0

# Direct OpenAI fallback used only after every OpenRouter free model is
# exhausted in a given run. Optional but strongly recommended for reliable
# daily runs — get a key at https://platform.openai.com/api-keys.
# Leave the placeholder if you want OpenRouter-only and accept that
# enrichment may stall when free models are saturated.
OPENAI_API_KEY="sk-..."
OPENAI_FALLBACK_MODEL="gpt-5.4-nano"

# Optional paid OpenRouter fallback (set on the command line for one-off
# runs, e.g. `OPENROUTER_PAID_FALLBACK_MODEL=deepseek/deepseek-chat pnpm pipeline:run`).
# Used only after both free OpenRouter models and OpenAI fallback fail.
# OPENROUTER_PAID_FALLBACK_MODEL=

# ─────────────────────────────────────────────────────────────────────────────
# Caches
# ─────────────────────────────────────────────────────────────────────────────

# On-disk LLM response cache (.cache/llm by default). Set to "true" to bypass
# entirely, or override the directory with LLM_CACHE_DIR.
LLM_CACHE_DISABLE=false
# LLM_CACHE_DIR=/custom/path/.cache/llm

# On-disk article-text extraction cache (.cache/articles by default, 7-day TTL).
# Caches successful Playwright extractions keyed by URL.
ARTICLE_TEXT_CACHE_DISABLE=false
# ARTICLE_TEXT_CACHE_DIR=/custom/path/.cache/articles

# ─────────────────────────────────────────────────────────────────────────────
# Sidecar services
# ─────────────────────────────────────────────────────────────────────────────

# Perspective Intelligence sidecar (apps/perspective). SBERT + RoBERTa + TF-IDF.
# Started locally with `uv run python app.py` from apps/perspective. Stage 4
# of the pipeline calls this; without it, divergence scores and distinctive
# words are not produced.
PERSPECTIVE_SIDECAR_URL="http://127.0.0.1:5710"
PERSPECTIVE_SIDECAR_TIMEOUT_MS=120000

# spaCy NER sidecar (apps/ner). Started via `docker compose up -d ner`.
# Used by article entity enrichment in stage 3.
NER_SERVICE_URL="http://127.0.0.1:5711"
NER_SERVICE_TIMEOUT_MS=30000
