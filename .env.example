DATABASE_URL="postgresql://postgres:postgres@localhost:55432/news_in_perspective?schema=public"
PORT=4400
HOST=0.0.0.0
WEB_ORIGIN="http://localhost:5317"
APP_DATE_TIMEZONE="UTC"
KAGI_KITE_URL="https://raw.githubusercontent.com/kagisearch/kite-public/main/kite_feeds.json"
AUTO_INGEST=false
AUTO_INGEST_TIME_UTC="12:30"
RSS_FETCH_TIMEOUT_MS=10000
ARTICLE_FETCH_TIMEOUT_MS=15000
ARTICLE_FETCH_USER_AGENT="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/136.0.0.0 Safari/537.36"
ARTICLE_BROWSER_TIMEOUT_MS=30000
INGEST_FEED_LIMIT=50
# Kagi ingest extraction (Playwright headless Chromium) concurrency.
# Each unit = one Chrome page in flight. Lower if your machine struggles.
KAGI_INGEST_EXTRACTION_CONCURRENCY=4
KAGI_INGEST_EXTRACTION_PER_DOMAIN_CONCURRENCY=2
KAGI_INGEST_EXTRACTION_RETRIES=1
# Skip clusters already present in DB (matched by storyId + snapshot date).
# Set to "false" to force re-extraction of every selected cluster.
KAGI_INGEST_SKIP_EXISTING=true
OPENROUTER_API_KEY="sk-or-v1-...."
# Free-model rotation, refreshed against https://openrouter.ai/collections/free-models.
# Ordered with structured-output / function-calling models first.
OPENROUTER_MODEL="openai/gpt-oss-120b:free,google/gemma-4-31b-it:free,google/gemma-4-26b-a4b-it:free,openai/gpt-oss-20b:free,tencent/hy3-preview:free,nvidia/nemotron-3-super-120b-a12b:free,inclusionai/ling-2.6-1t:free,z-ai/glm-4.5-air:free,minimax/minimax-m2.5:free,openrouter/owl-alpha,nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free,nvidia/nemotron-3-nano-30b-a3b:free,poolside/laguna-m.1:free,poolside/laguna-xs.2:free"
OPENROUTER_MODEL_OFFSET=0
# Direct OpenAI fallback used when every OpenRouter free model is exhausted.
OPENAI_API_KEY="sk-..."
OPENAI_FALLBACK_MODEL="gpt-5.4-nano"
# On-disk LLM response cache (.cache/llm by default). Set to "true" to bypass
# entirely, or override the directory with LLM_CACHE_DIR.
LLM_CACHE_DISABLE=false
# LLM_CACHE_DIR=/custom/path/.cache/llm
# On-disk article-text extraction cache (.cache/articles by default, 7-day TTL).
# Caches successful Playwright extractions keyed by URL.
ARTICLE_TEXT_CACHE_DISABLE=false
# ARTICLE_TEXT_CACHE_DIR=/custom/path/.cache/articles
KAGI_DEDUPE_STRATEGY="simhash"
KAGI_DEDUPE_SIMHASH_MIN_JACCARD=0.90
# Perspective Intelligence sidecar (apps/perspective). SBERT + RoBERTa + TF-IDF.
PERSPECTIVE_SIDECAR_URL="http://127.0.0.1:5710"
PERSPECTIVE_SIDECAR_TIMEOUT_MS=120000
# spaCy NER sidecar (apps/ner). Used by article entity enrichment.
NER_SERVICE_URL="http://127.0.0.1:5711"
NER_SERVICE_TIMEOUT_MS=30000
# Toggle for kagi-ingest to call entity enrichment after each ingested article.
ENABLE_ENTITY_ENRICHMENT=false
