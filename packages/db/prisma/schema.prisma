generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EntityType {
  PERSON
  GPE
  ORG
  EVENT
}

enum RunStatus {
  PENDING
  SUCCESS
  PARTIAL
  FAILED
}

enum ScopeType {
  ARTICLE
  CLUSTER
  GLOBAL
}

enum ExtractionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PipelineJobStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

enum PipelineTrigger {
  MANUAL
  SCHEDULED
}

model FeedSource {
  id          String      @id @default(cuid())
  url         String      @unique
  category    String?
  sourceName  String?
  domain      String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  fetches     FeedFetch[]
  articles    Article[]
}

model IngestionRun {
  id             String       @id @default(cuid())
  ingestionDate  DateTime
  status         RunStatus    @default(PENDING)
  startedAt      DateTime     @default(now())
  finishedAt     DateTime?
  feedCount      Int          @default(0)
  articleCount   Int          @default(0)
  clusterCount   Int          @default(0)
  errorSummary   Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  feedFetches    FeedFetch[]

  @@unique([ingestionDate])
}

model FeedFetch {
  id             String        @id @default(cuid())
  runId          String
  feedSourceId   String
  statusCode     Int?
  ok             Boolean       @default(false)
  fetchedAt      DateTime      @default(now())
  errorMessage   String?
  rawHash        String?
  itemCount      Int           @default(0)
  run            IngestionRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  feedSource     FeedSource    @relation(fields: [feedSourceId], references: [id], onDelete: Cascade)
  raws           ArticleRaw[]

  @@unique([runId, feedSourceId])
}

model Article {
  id              String           @id @default(cuid())
  canonicalUrl    String           @unique
  originalUrl     String
  textFingerprint String?          @unique
  title           String
  summary         String?
  contentSnippet  String?
  fullText        String?
  fullTextFormat  String?
  translatedTitle    String?
  translatedSummary  String?
  translatedFullText String?
  extractionStatus ExtractionStatus @default(PENDING)
  extractedAt     DateTime?
  extractionError String?
  publishedAt     DateTime?
  sourceName      String
  domain          String
  duplicateDomains String[]
  duplicateCount  Int              @default(0)
  language        String?
  category        String?
  ingestionDate   DateTime
  authorNames     String[]
  feedSourceId    String?
  feedSource      FeedSource?      @relation(fields: [feedSourceId], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  raws            ArticleRaw[]
  clusterLinks    ClusterArticle[]
  features        NlpFeature[]
  entityMentions  EntityMention[]

  @@index([textFingerprint])
}

model ArticleRaw {
  id           String     @id @default(cuid())
  articleId    String?
  feedFetchId  String
  payload      Json
  article      Article?   @relation(fields: [articleId], references: [id], onDelete: SetNull)
  feedFetch    FeedFetch  @relation(fields: [feedFetchId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
}

model StoryCluster {
  id              String           @id @default(cuid())
  clusterKey      String
  storyDate       DateTime
  title           String
  translatedTitle String?
  topCategory     String?
  articleCount  Int              @default(0)
  sourceCount   Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  articles      ClusterArticle[]
  features      NlpFeature[]

  @@unique([clusterKey, storyDate])
}

model ClusterArticle {
  id             String        @id @default(cuid())
  clusterId      String
  articleId      String
  rank           Int           @default(0)
  similarity     Float         @default(0)
  cluster        StoryCluster  @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  article        Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([clusterId, articleId])
}

model SourceProfile {
  id                 String     @id @default(cuid())
  domain             String     @unique
  sourceName         String
  description        String?
  country            String?
  countryOfOrigin    String?
  headquarters       String?
  mediaOwner         String?
  ownershipType      String?
  employeeCount      Int?
  wikipediaUrl       String?
  associatedEntities String[]
  articleCount       Int        @default(0)
  averageSentiment   Float      @default(0)
  commonBiasSignals  String[]
  lastEnrichedAt     DateTime?
  enrichmentModel    String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

model NamedEntity {
  id                String      @id @default(cuid())
  name              String      @unique
  type              EntityType
  wikiId            String?     @unique
  wikipediaUrl      String?
  wikidataId        String?
  summary           String?     @db.Text
  imageUrl          String?
  infoboxJson       Json?
  firstSeen         DateTime    @default(now())
  lastUpdated       DateTime    @updatedAt

  mentions          EntityMention[]
  statistics        EntityStatistics?
  cooccurrence1     EntityCooccurrence[] @relation("entity1")
  cooccurrence2     EntityCooccurrence[] @relation("entity2")

  @@index([name])
  @@index([type])
}

model EntityMention {
  id                String      @id @default(cuid())
  entityId          String
  entity            NamedEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  articleId         String
  article           Article     @relation(fields: [articleId], references: [id], onDelete: Cascade)
  startOffset       Int
  endOffset         Int
  context           String
  confidence        Float?
  createdAt         DateTime    @default(now())

  @@index([entityId])
  @@index([articleId])
  @@index([confidence])
}

model EntityStatistics {
  id                String      @id @default(cuid())
  entityId          String      @unique
  entity            NamedEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  totalMentions     Int         @default(0)
  uniqueArticles    Int         @default(0)
  mentions7Days     Int         @default(0)
  mentions30Days    Int         @default(0)
  averagePosition   Float?
  lastUpdated       DateTime    @updatedAt
}

model EntityCooccurrence {
  id                String      @id @default(cuid())
  entity1Id         String
  entity1           NamedEntity @relation("entity1", fields: [entity1Id], references: [id], onDelete: Cascade)
  entity2Id         String
  entity2           NamedEntity @relation("entity2", fields: [entity2Id], references: [id], onDelete: Cascade)
  cooccurrenceCount Int         @default(0)
  lastDate          DateTime    @default(now())

  @@unique([entity1Id, entity2Id])
  @@index([entity1Id])
  @@index([entity2Id])
}

model NlpFeature {
  id         String      @id @default(cuid())
  scopeType  ScopeType
  articleId  String?
  clusterId  String?
  featureSet Json
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  article    Article?    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  cluster    StoryCluster? @relation(fields: [clusterId], references: [id], onDelete: Cascade)
}

model PipelineJob {
  id          String            @id @default(cuid())
  kind        String
  target      String?
  args        Json?
  status      PipelineJobStatus @default(QUEUED)
  trigger     PipelineTrigger   @default(MANUAL)
  queuedAt    DateTime          @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?
  exitCode    Int?
  pid         Int?
  message     String?
  progress    Json?
  logTail     String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([status, queuedAt])
  @@index([kind, queuedAt])
}
